<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.student.mapper.StudentMapper">

    <resultMap id="StudentResultMap" type="com.example.student.Student">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="address" property="address"/>
        <result column="dob" property="dob" javaType="java.time.LocalDate"/>
        <result column="grade" property="grade"/>
        <result column="gender" property="gender"/>
    </resultMap>

    <insert id="insertStudent" parameterType="com.example.student.Student"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO students (name, address, dob, grade, gender)
        VALUES (#{name}, #{address}, #{dob}, #{grade}, #{gender})
    </insert>

    <select id="getStudentByRollNumber" parameterType="int" resultMap="StudentResultMap">
        SELECT id, name, address, dob, grade, gender
        FROM students
        WHERE id = #{roll_no}
    </select>

    <select id="getAllStudents" resultMap="StudentResultMap">
        SELECT id, name, address, dob, grade, gender
        FROM students
        ORDER BY id
    </select>

    <update id="updateStudent" parameterType="com.example.student.Student">
        UPDATE students
        SET name = #{name},
            address = #{address},
            dob = #{dob},
            grade = #{grade},
            gender = #{gender}
        WHERE id = #{id}
    </update>

    <delete id="deleteStudent" parameterType="int">
        DELETE FROM students
        WHERE id = #{id}
    </delete>
</mapper>
